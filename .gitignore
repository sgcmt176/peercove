/target
/target-smoke
# サービス稼働中(exe ロック中)の更新ビルド先
/target-v012
*.key
# 実環境の設定(例は examples/ に置く)
/host.toml
/member*.toml
# 実行中プロセスが書き出すステータスファイル
*.status.txt
# 招待トークン(秘密情報)
*.token

# UI(Tauri + Vite)
/apps/peercove-ui/node_modules
/apps/peercove-ui/dist
/apps/peercove-ui/src-tauri/target
/apps/peercove-ui/src-tauri/gen
# wintun.dll は再配布素材(wintun.net の署名済みバイナリ)。リポジトリには
# 含めず、インストーラのビルド前に手で配置する(daemon-service.wxs 参照)
/apps/peercove-ui/src-tauri/windows/wintun.dll
# wintun のライセンス本文も同 zip 由来の再配布素材(packaging/licenses/README.md)
/packaging/licenses/wintun-LICENSE.txt
# wintun zip の展開先(ここに置く運用の場合)。再配布素材なので追跡しない
/wintun/
# ポータブル版 ZIP/tar の組み立て成果物
/packaging/dist
# MSI 等のインストールログ
*.log
*.psk

# Claude Code のローカル権限設定(マシン固有・共有しない)
/.claude/settings.local.json
# Claude Code のブラウザプレビュー設定(開発機ローカル)
/.claude/launch.json
