<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- WG トンネルの UDP 通信 -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- 招待 QR コードの読み取り(zxing)。カメラ無し端末でも動くようにする -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <!-- VPN の常駐(Foreground Service + 継続通知)と回線切替の検知(E-D)。
         systemExempted は VpnService を持つアプリに許可されている型 -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SYSTEM_EXEMPTED" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- メモのリマインダー(M5 F-5 Stage 5、ADR-0052 決定 6)。再起動後の
         再登録に使う。SCHEDULE_EXACT_ALARM は要求しない(inexact で十分) -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <application
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:theme="@android:style/Theme.Material.Light.NoActionBar"
        android:allowBackup="false">

        <!-- adjustNothing: キーボードでウィンドウを縮めない(端末により
             enableEdgeToEdge だけでは縮む)。持ち上げは Compose のインセット
             (safeDrawingPadding = ime を含む union)が一手に担う -->
        <activity
            android:name=".MainActivity"
            android:windowSoftInputMode="adjustNothing"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- 他アプリの共有シートからファイルを受け取る(→ メンバーを選んで送信) -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="*/*" />
            </intent-filter>
        </activity>

        <!-- QR 読み取り(縦向き固定。zxing の既定は横向きのため) -->
        <activity
            android:name=".PortraitCaptureActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:stateNotNeeded="true"
            android:theme="@style/zxing_CaptureTheme"
            android:windowSoftInputMode="stateAlwaysHidden" />

        <!-- VPN サービス。BIND_VPN_SERVICE はシステムだけが持つ権限なので、
             exported でも第三者アプリからは bind できない -->
        <service
            android:name=".PeercoveVpnService"
            android:permission="android.permission.BIND_VPN_SERVICE"
            android:foregroundServiceType="systemExempted"
            android:exported="true">
            <intent-filter>
                <action android:name="android.net.VpnService" />
            </intent-filter>
        </service>

        <!-- チャット通知のアクション(返信・既読)受け口 -->
        <receiver android:name=".ChatActionReceiver" android:exported="false" />

        <!-- メモのリマインダー(M5 F-5 Stage 5、ADR-0052 決定 6)。AlarmManager
             の発火受け口と、端末再起動後の再登録 -->
        <receiver android:name=".ReminderReceiver" android:exported="false" />
        <receiver android:name=".ReminderBootReceiver" android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- クイック設定タイル(通知シェードから 1 タップで接続/切断) -->
        <service
            android:name=".PeercoveTileService"
            android:icon="@drawable/ic_tile"
            android:label="@string/app_name"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE"
            android:exported="true">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <!-- 受信ファイルを他アプリで「開く」「共有」するための content URI 提供 -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>

</manifest>
