<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- WG トンネルの UDP 通信 -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- 招待 QR コードの読み取り(zxing)。カメラ無し端末でも動くようにする -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <application
        android:label="@string/app_name"
        android:icon="@android:mipmap/sym_def_app_icon"
        android:theme="@android:style/Theme.Material.Light.NoActionBar"
        android:allowBackup="false">

        <!-- adjustNothing: キーボードでウィンドウを縮めない(端末により
             enableEdgeToEdge だけでは縮む)。持ち上げは Compose のインセット
             (safeDrawingPadding = ime を含む union)が一手に担う -->
        <activity
            android:name=".MainActivity"
            android:windowSoftInputMode="adjustNothing"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- QR 読み取り(縦向き固定。zxing の既定は横向きのため) -->
        <activity
            android:name=".PortraitCaptureActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:stateNotNeeded="true"
            android:theme="@style/zxing_CaptureTheme"
            android:windowSoftInputMode="stateAlwaysHidden" />

        <!-- VPN サービス。BIND_VPN_SERVICE はシステムだけが持つ権限なので、
             exported でも第三者アプリからは bind できない -->
        <service
            android:name=".PeercoveVpnService"
            android:permission="android.permission.BIND_VPN_SERVICE"
            android:exported="true">
            <intent-filter>
                <action android:name="android.net.VpnService" />
            </intent-filter>
        </service>
    </application>

</manifest>
